// ============================================
// SAAS BILLING — SUBSCRIPTION PLANS (T-108)
// ============================================

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE // to'lov kechikkan — grace period (3 kun)
  CANCELLED
  EXPIRED
}

model SubscriptionPlan {
  id           String  @id @default(uuid())
  name         String  @unique // "Free", "Basic", "Pro", "Enterprise"
  slug         String  @unique // "free", "basic", "pro", "enterprise"
  priceMonthly Decimal @map("price_monthly") @db.Decimal(15, 2)
  maxBranches  Int     @map("max_branches") // -1 = unlimited
  maxProducts  Int     @map("max_products") // -1 = unlimited
  maxUsers     Int     @map("max_users") // -1 = unlimited
  trialDays    Int     @default(14) @map("trial_days")
  features     Json    @default("[]") // feature flags list
  isActive     Boolean @default(true) @map("is_active")
  sortOrder    Int     @default(0) @map("sort_order")

  subscriptions TenantSubscription[]

  @@map("subscription_plans")
}

model TenantSubscription {
  id                String             @id @default(uuid())
  tenantId          String             @unique @map("tenant_id") // 1 tenant — 1 active sub
  planId            String             @map("plan_id")
  status            SubscriptionStatus @default(TRIAL)
  startedAt         DateTime           @default(now()) @map("started_at")
  expiresAt         DateTime?          @map("expires_at")
  trialEndsAt       DateTime?          @map("trial_ends_at")
  gracePeriodEndsAt DateTime?          @map("grace_period_ends_at")
  cancelledAt       DateTime?          @map("cancelled_at")
  notes             String?
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  tenant Tenant           @relation(fields: [tenantId], references: [id])
  plan   SubscriptionPlan @relation(fields: [planId], references: [id])

  @@index([status])
  @@index([expiresAt])
  @@map("tenant_subscriptions")
}

