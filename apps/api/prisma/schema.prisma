// ─── T-062: Outbox / POS Sync ───────────────────────────────────

enum SyncEventType {
  SALE_CREATED
  PAYMENT_SETTLED
  RETURN_CREATED
  STOCK_MOVEMENT
}

enum SyncEventStatus {
  PENDING
  PROCESSED
  FAILED
  DUPLICATE
}

model SyncOutbox {
  id             String          @id @default(uuid())
  tenantId       String          @map("tenant_id")
  branchId       String?         @map("branch_id")
  deviceId       String          @map("device_id") // POS qurilma identifikatori
  eventType      SyncEventType   @map("event_type")
  payload        Json
  idempotencyKey String          @unique @map("idempotency_key")
  sequenceNumber BigInt          @map("sequence_number") // POS tomonidan beriladi
  status         SyncEventStatus @default(PENDING)
