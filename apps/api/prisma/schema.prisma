generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// IDENTITY & MULTI-TENANT
// ============================================

model Tenant {
  id           String   @id @default(uuid())
  name         String
  slug         String   @unique
  isActive     Boolean  @default(true)
  // T-079: Soliq ma'lumotlari
  inn          String? // INN: 9 (yuridik) yoki 14 (jismoniy) raqam
  stir         String? // STIR (soliq to'lovchi identifikator raqami)
  oked         String? // OKED (faoliyat turi kodi)
  legalName    String?  @map("legal_name") // Rasmiy nomi
  legalAddress String?  @map("legal_address") // Yuridik manzil
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  users          User[]
  branches       Branch[]
  categories     Category[]
  units          Unit[]
  products       Product[]
  shifts         Shift[]
  orders         Order[]
  returns        Return[]
  warehouses     Warehouse[]
  customers      Customer[]
  debtRecords    DebtRecord[]
  paymentIntents PaymentIntent[]
  suppliers      Supplier[]
  zReports       ZReport[]
  notifications  Notification[]
  subscription   TenantSubscription?
  sessions            Session[]
  apiKeys             ApiKey[]
  StockMovement       StockMovement[]
  stockTransfers      StockTransfer[]
  productCertificates ProductCertificate[]
  promotions          Promotion[]
  telegramLinkTokens  TelegramLinkToken[]
  settings            TenantSettings?
  priceChanges        PriceChange[]
  tasks               Task[]
  properties          Property[]
  rentalContracts     RentalContract[]
  rentalPayments      RentalPayment[]
  eventLogs           EventLog[]
  auditLogs           AuditLog[]
  expenses            Expense[]
  reminderLogs        ReminderLog[]
  clientErrorLogs     ClientErrorLog[]

  @@map("tenants")
}

model User {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  email           String
  passwordHash    String    @map("password_hash")
  firstName       String    @map("first_name")
  lastName        String    @map("last_name")
  role            UserRole  @default(CASHIER)
  isActive        Boolean   @default(true)
  refreshToken    String?   @map("refresh_token")
  refreshTokenExp DateTime? @map("refresh_token_exp")
  // Admin PIN (T-068) — 4-6 raqamli bcrypt hash
  pinHash         String?   @map("pin_hash")
  pinLockedUntil  DateTime? @map("pin_locked_until")
  telegramChatId  String?   @map("telegram_chat_id")
  botSettings     Json?     @map("bot_settings")
  branchId        String?   @map("branch_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  branch         Branch?         @relation(fields: [branchId], references: [id])
  shifts         Shift[]
  orders         Order[]
  returns               Return[]
  stockMovements        StockMovement[]
  notifications         Notification[]
  fcmTokens             FcmToken[]
  sessions              Session[]
  requestedTransfers    StockTransfer[]     @relation("TransferRequested")
  approvedTransfers     StockTransfer[]     @relation("TransferApproved")
  telegramLinkTokens    TelegramLinkToken[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

model Branch {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant            Tenant          @relation(fields: [tenantId], references: [id])
  users             User[]
  customers         Customer[]
  shifts            Shift[]
  orders            Order[]
  warehouses        Warehouse[]
  apiKeys           ApiKey[]
  outboundTransfers StockTransfer[] @relation("TransferFrom")
  inboundTransfers  StockTransfer[] @relation("TransferTo")

  @@index([tenantId])
  @@map("branches")
}

// ============================================
// EVENT LOG (Domain Events — immutable)
// ============================================

model EventLog {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  eventType   String   @map("event_type")
  aggregateId String   @map("aggregate_id")
  payload     Json
  occurredAt  DateTime @default(now()) @map("occurred_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([eventType])
  @@index([aggregateId])
  @@map("event_log")
}

// ============================================
// CATALOG MODULE
// ============================================

model Category {
  id        String    @id @default(uuid())
  tenantId  String    @map("tenant_id")
  name      String
  parentId  String?   @map("parent_id")
  sortOrder Int       @default(0) @map("sort_order")
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  tenant   Tenant     @relation(fields: [tenantId], references: [id])
  parent   Category?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children Category[] @relation("CategoryChildren")
  products Product[]

  @@unique([tenantId, name, parentId])
  @@index([tenantId])
  @@index([tenantId, parentId])
  @@map("categories")
}

model Unit {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String
  shortName String   @map("short_name")
  createdAt DateTime @default(now()) @map("created_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  products Product[]

  @@unique([tenantId, shortName])
  @@index([tenantId])
  @@map("units")
}

model Product {
  id             String    @id @default(uuid())
  tenantId       String    @map("tenant_id")
  categoryId     String?   @map("category_id")
  unitId         String?   @map("unit_id")
  name           String
  sku            String?
  barcode        String?
  costPrice      Decimal   @default(0) @map("cost_price") @db.Decimal(15, 2)
  costCurrency   String    @default("UZS") @map("cost_currency") // T-082: UZS|USD
  sellPrice      Decimal   @default(0) @map("sell_price") @db.Decimal(15, 2)
  minStockLevel  Decimal   @default(0) @map("min_stock_level") @db.Decimal(15, 3)
  isActive       Boolean   @default(true) @map("is_active")
  isBundle       Boolean   @default(false) @map("is_bundle")
  imageUrl       String?   @map("image_url")
  description    String?
  expiryTracking Boolean   @default(false) @map("expiry_tracking")
  isTaxable      Boolean   @default(true)  @map("is_taxable")  // T-078: QQS (НДС 12%)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  category         Category?         @relation(fields: [categoryId], references: [id])
  unit             Unit?             @relation(fields: [unitId], references: [id])
  barcodes         ProductBarcode[]
  variants         ProductVariant[]
  orderItems       OrderItem[]
  stockMovements   StockMovement[]
  returnItems      ReturnItem[]
  productSuppliers ProductSupplier[]
  bundleItems      BundleItem[]        @relation("BundleComponents")
  componentOf      BundleItem[]        @relation("ComponentOfBundles")
  prices           ProductPrice[]
  transferItems    StockTransferItem[]
  certificates     ProductCertificate[]
  priceChanges     PriceChange[]

  @@unique([tenantId, sku])
  @@unique([tenantId, barcode])
  @@index([tenantId])
  @@index([tenantId, categoryId])
  @@index([tenantId, isActive]) // T-074: active products filter
  @@index([tenantId, isActive, name]) // T-074: active + search
  @@map("products")
}

model ProductBarcode {
  id        String   @id @default(uuid())
  productId String   @map("product_id")
  barcode   String
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([barcode])
  @@index([productId])
  @@map("product_barcodes")
}

// ============================================
// STOCK SNAPSHOTS (T-075) — Hourly materialized view
// ============================================

model StockSnapshot {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  warehouseId  String   @map("warehouse_id")
  productId    String   @map("product_id")
  quantity     Decimal  @default(0) @db.Decimal(15, 3)
  calculatedAt DateTime @map("calculated_at")

  @@unique([tenantId, warehouseId, productId])
  @@index([tenantId, productId])
  @@index([tenantId, warehouseId])
  @@map("stock_snapshots")
}

// ============================================
// PRODUCT VARIANTS (T-095) — Rang/hajm/tur
// ============================================

model ProductVariant {
  id           String   @id @default(uuid())
  productId    String   @map("product_id")
  tenantId     String   @map("tenant_id")
  name         String // e.g. "Qizil 50ml"
  sku          String?
  barcode      String?
  costPrice    Decimal  @default(0) @map("cost_price") @db.Decimal(15, 2)
  costCurrency String   @default("UZS") @map("cost_currency")
  sellPrice    Decimal  @default(0) @map("sell_price") @db.Decimal(15, 2)
  isActive     Boolean  @default(true) @map("is_active")
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([tenantId])
  @@index([tenantId, barcode])
  @@map("product_variants")
}

// ============================================
// BUNDLE/SETS MODULE (T-045)
// ============================================

model BundleItem {
  id          String  @id @default(uuid())
  bundleId    String  @map("bundle_id")
  componentId String  @map("component_id")
  quantity    Decimal @db.Decimal(15, 3)

  bundle    Product @relation("BundleComponents", fields: [bundleId], references: [id], onDelete: Cascade)
  component Product @relation("ComponentOfBundles", fields: [componentId], references: [id])

  @@unique([bundleId, componentId])
  @@index([bundleId])
  @@map("bundle_items")
}

// ============================================
// SUPPLIER MODULE (T-042)
// ============================================

model Supplier {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String
  phone     String?
  company   String?
  address   String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  productSuppliers ProductSupplier[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("suppliers")
}

model ProductSupplier {
  id          String  @id @default(uuid())
  productId   String  @map("product_id")
  supplierId  String  @map("supplier_id")
  supplyPrice Decimal @map("supply_price") @db.Decimal(15, 2)
  isDefault   Boolean @default(false) @map("is_default")

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@unique([productId, supplierId])
  @@index([productId])
  @@index([supplierId])
  @@map("product_suppliers")
}

// ============================================
// INVENTORY MODULE
// ============================================

model Warehouse {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  branchId  String?  @map("branch_id")
  name      String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  branch         Branch?         @relation(fields: [branchId], references: [id])
  stockMovements  StockMovement[]
  transferItems   StockTransferItem[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("warehouses")
}

model StockMovement {
  id          String            @id @default(uuid())
  tenantId    String            @map("tenant_id")
  warehouseId String            @map("warehouse_id")
  productId   String            @map("product_id")
  userId      String?           @map("user_id")
  type        StockMovementType
  quantity    Decimal           @db.Decimal(15, 3)
  costPrice   Decimal?          @map("cost_price") @db.Decimal(15, 2)
  note        String?
  refId       String?           @map("ref_id")
  refType     String?           @map("ref_type")
  batchNumber String?           @map("batch_number")
  expiryDate  DateTime?         @map("expiry_date")
  createdAt   DateTime          @default(now()) @map("created_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  product   Product   @relation(fields: [productId], references: [id])
  user      User?     @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([tenantId, productId])
  @@index([tenantId, warehouseId])
  @@index([tenantId, createdAt])
  @@index([tenantId, productId, warehouseId]) // T-074: stock level aggregate
  @@index([tenantId, type, createdAt]) // T-074: movement type filter
  @@map("stock_movements")
}

// ============================================
// STOCK TRANSFER MODULE (T-114)
// ============================================

enum TransferStatus {
  REQUESTED
  APPROVED
  SHIPPED
  RECEIVED
  CANCELLED
}

model StockTransfer {
  id            String         @id @default(uuid())
  tenantId      String         @map("tenant_id")
  fromBranchId  String         @map("from_branch_id")
  toBranchId    String         @map("to_branch_id")
  status        TransferStatus @default(REQUESTED)
  requestedById String         @map("requested_by_id")
  approvedById  String?        @map("approved_by_id")
  notes         String?
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  tenant      Tenant               @relation(fields: [tenantId], references: [id])
  fromBranch  Branch               @relation("TransferFrom", fields: [fromBranchId], references: [id])
  toBranch    Branch               @relation("TransferTo", fields: [toBranchId], references: [id])
  requestedBy User                 @relation("TransferRequested", fields: [requestedById], references: [id])
  approvedBy  User?                @relation("TransferApproved", fields: [approvedById], references: [id])
  items       StockTransferItem[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("stock_transfers")
}

model StockTransferItem {
  id          String  @id @default(uuid())
  transferId  String  @map("transfer_id")
  productId   String  @map("product_id")
  warehouseId String? @map("warehouse_id")
  quantity    Decimal @db.Decimal(15, 3)

  transfer  StockTransfer @relation(fields: [transferId], references: [id])
  product   Product       @relation(fields: [productId], references: [id])
  warehouse Warehouse?    @relation(fields: [warehouseId], references: [id])

  @@index([transferId])
  @@map("stock_transfer_items")
}

// ============================================
// SALES MODULE
// ============================================

model Shift {
  id           String      @id @default(uuid())
  tenantId     String      @map("tenant_id")
  userId       String      @map("user_id")
  branchId     String?     @map("branch_id")
  status       ShiftStatus @default(OPEN)
  openedAt     DateTime    @default(now()) @map("opened_at")
  closedAt     DateTime?   @map("closed_at")
  openingCash  Decimal     @default(0) @map("opening_cash") @db.Decimal(15, 2)
  closingCash  Decimal?    @map("closing_cash") @db.Decimal(15, 2)
  expectedCash Decimal?    @map("expected_cash") @db.Decimal(15, 2)
  notes        String?
  createdAt    DateTime    @default(now()) @map("created_at")

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  user   User    @relation(fields: [userId], references: [id])
  branch Branch? @relation(fields: [branchId], references: [id])
  orders Order[]

  @@index([tenantId])
  @@index([tenantId, userId])
  @@index([tenantId, status])
  @@map("shifts")
}

model Order {
  id             String       @id @default(uuid())
  tenantId       String       @map("tenant_id")
  shiftId        String?      @map("shift_id")
  userId         String       @map("user_id")
  branchId       String?      @map("branch_id")
  customerId     String?      @map("customer_id")
  orderNumber    Int          @map("order_number")
  status         OrderStatus  @default(COMPLETED)
  subtotal       Decimal      @db.Decimal(15, 2)
  discountAmount Decimal      @default(0) @map("discount_amount") @db.Decimal(15, 2)
  discountType   DiscountType @default(FIXED) @map("discount_type")
  taxAmount      Decimal      @default(0) @map("tax_amount") @db.Decimal(15, 2)
  total          Decimal      @db.Decimal(15, 2)
  notes          String?
  fiscalStatus   FiscalStatus @default(NONE) @map("fiscal_status")
  fiscalId       String?      @map("fiscal_id")
  fiscalQr       String?      @map("fiscal_qr")
  createdAt      DateTime     @default(now()) @map("created_at")

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  shift          Shift?          @relation(fields: [shiftId], references: [id])
  user           User            @relation(fields: [userId], references: [id])
  branch         Branch?         @relation(fields: [branchId], references: [id])
  customer       Customer?       @relation(fields: [customerId], references: [id])
  items          OrderItem[]
  returns        Return[]
  paymentIntents PaymentIntent[]

  @@unique([tenantId, orderNumber])
  @@index([tenantId])
  @@index([tenantId, shiftId])
  @@index([tenantId, createdAt])
  @@index([tenantId, customerId])
  @@index([tenantId, userId]) // T-074: cashier performance reports
  @@index([tenantId, status, createdAt]) // T-074: status filter + date range
  @@map("orders")
}

model OrderItem {
  id             String  @id @default(uuid())
  orderId        String  @map("order_id")
  productId      String  @map("product_id")
  productName    String  @map("product_name")
  quantity       Decimal @db.Decimal(15, 3)
  unitPrice      Decimal @map("unit_price") @db.Decimal(15, 2)
  costPrice      Decimal @default(0) @map("cost_price") @db.Decimal(15, 2)
  discountAmount Decimal @default(0) @map("discount_amount") @db.Decimal(15, 2)
  total          Decimal @db.Decimal(15, 2)

  order       Order        @relation(fields: [orderId], references: [id])
  product     Product      @relation(fields: [productId], references: [id])
  returnItems ReturnItem[]

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model Return {
  id         String       @id @default(uuid())
  tenantId   String       @map("tenant_id")
  orderId    String       @map("order_id")
  userId     String       @map("user_id")
  reason     String?
  total      Decimal      @db.Decimal(15, 2)
  status     ReturnStatus @default(PENDING)
  approvedBy String?      @map("approved_by")
  createdAt  DateTime     @default(now()) @map("created_at")

  tenant Tenant       @relation(fields: [tenantId], references: [id])
  order  Order        @relation(fields: [orderId], references: [id])
  user   User         @relation(fields: [userId], references: [id])
  items  ReturnItem[]

  @@index([tenantId])
  @@index([tenantId, orderId])
  @@map("returns")
}

model ReturnItem {
  id          String  @id @default(uuid())
  returnId    String  @map("return_id")
  orderItemId String  @map("order_item_id")
  productId   String  @map("product_id")
  quantity    Decimal @db.Decimal(15, 3)
  amount      Decimal @db.Decimal(15, 2)

  return    Return    @relation(fields: [returnId], references: [id])
  orderItem OrderItem @relation(fields: [orderItemId], references: [id])
  product   Product   @relation(fields: [productId], references: [id])

  @@index([returnId])
  @@map("return_items")
}

// ============================================
// PAYMENTS MODULE
// ============================================

model PaymentIntent {
  id          String              @id @default(uuid())
  tenantId    String              @map("tenant_id")
  orderId     String              @map("order_id")
  method      PaymentMethod
  status      PaymentIntentStatus @default(CREATED)
  amount      Decimal             @db.Decimal(15, 2)
  provider    String?
  providerRef String?             @map("provider_ref")
  commission  Decimal?            @db.Decimal(15, 2)
  meta        Json?
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  order  Order  @relation(fields: [orderId], references: [id])

  @@index([tenantId])
  @@index([tenantId, orderId])
  @@index([status])
  @@map("payment_intents")
}

// ============================================
// CUSTOMER MODULE (T-050)
// ============================================

model Customer {
  id             String    @id @default(uuid())
  tenantId       String    @map("tenant_id")
  name           String
  phone          String?
  email          String?
  birthDate      DateTime? @map("birth_date")
  address        String?
  gender         String?
  debtLimit      Int       @default(0) @map("debt_limit")
  notes          String?
  isActive       Boolean   @default(true) @map("is_active")
  telegramChatId String?   @map("telegram_chat_id")
  branchId       String?   @map("branch_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  tenant              Tenant              @relation(fields: [tenantId], references: [id])
  branch              Branch?             @relation(fields: [branchId], references: [id])
  orders              Order[]
  debtRecords         DebtRecord[]
  loyaltyAccount      LoyaltyAccount?
  telegramLinkTokens  TelegramLinkToken[]

  @@index([tenantId])
  @@index([tenantId, phone])
  @@map("customers")
}

// ============================================
// NASIYA MODULE (T-051) — Debt/Credit
// ============================================

model DebtRecord {
  id          String     @id @default(uuid())
  tenantId    String     @map("tenant_id")
  customerId  String     @map("customer_id")
  orderId     String?    @map("order_id")
  totalAmount Decimal    @map("total_amount") @db.Decimal(15, 2)
  paidAmount  Decimal    @default(0) @map("paid_amount") @db.Decimal(15, 2)
  remaining   Decimal    @map("remaining") @db.Decimal(15, 2)
  dueDate     DateTime?  @map("due_date")
  status      DebtStatus @default(ACTIVE)
  notes       String?
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  tenant   Tenant        @relation(fields: [tenantId], references: [id])
  customer Customer      @relation(fields: [customerId], references: [id])
  payments DebtPayment[]

  @@index([tenantId])
  @@index([tenantId, customerId])
  @@index([tenantId, status])
  @@map("debt_records")
}

model DebtPayment {
  id           String        @id @default(uuid())
  debtRecordId String        @map("debt_record_id")
  amount       Decimal       @db.Decimal(15, 2)
  method       PaymentMethod @default(CASH)
  notes        String?
  createdAt    DateTime      @default(now()) @map("created_at")

  debtRecord DebtRecord @relation(fields: [debtRecordId], references: [id])

  @@index([debtRecordId])
  @@map("debt_payments")
}

// ============================================
// SUPER ADMIN (T-055) — SaaS Owner cross-tenant access
// ============================================

enum AdminRole {
  SUPER_ADMIN
  SUPPORT
}

model AdminUser {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  name         String
  role         AdminRole @default(SUPER_ADMIN)
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("admin_users")
}

// ============================================
// PUSH NOTIFICATIONS (T-103)
// ============================================

enum NotificationType {
  SALE_COMPLETED
  SHIFT_CHANGED
  ERROR_ALERT
  LOW_STOCK
  EXPIRY_WARNING
  LARGE_REFUND
  NASIYA_OVERDUE
  SYSTEM
}

model Notification {
