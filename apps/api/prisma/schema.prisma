  // earnRate: 1 point per earnRate so'm (e.g. 1000 → 1 point per 1000 so'm)
  earnRate   Decimal @default(1000) @map("earn_rate") @db.Decimal(15, 2)
  // redeemRate: 1 point = redeemRate so'm discount
