  createdAt DateTime      @default(now()) @map("created_at")
  // ⚠️ IMMUTABLE — updatedAt yo'q

  account LoyaltyAccount @relation(fields: [accountId], references: [id])

  @@index([tenantId])
  @@index([accountId])
  @@map("loyalty_transactions")
}

