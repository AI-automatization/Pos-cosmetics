// ============================================
// Z-REPORTS (T-083) — Kunlik fiskal yakuniy hisobot
// ============================================

model ZReport {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  sequenceNumber Int      @map("sequence_number")
  date           DateTime @db.Date
  totalOrders    Int      @default(0) @map("total_orders")
  totalRevenue   Decimal  @default(0) @map("total_revenue") @db.Decimal(15, 2)
  totalTax       Decimal  @default(0) @map("total_tax") @db.Decimal(15, 2)
  totalReturns   Decimal  @default(0) @map("total_returns") @db.Decimal(15, 2)
  cashAmount     Decimal  @default(0) @map("cash_amount") @db.Decimal(15, 2)
  terminalAmount Decimal  @default(0) @map("terminal_amount") @db.Decimal(15, 2)
  clickAmount    Decimal  @default(0) @map("click_amount") @db.Decimal(15, 2)
  paymeAmount    Decimal  @default(0) @map("payme_amount") @db.Decimal(15, 2)
  transferAmount Decimal  @default(0) @map("transfer_amount") @db.Decimal(15, 2)
  debtAmount     Decimal  @default(0) @map("debt_amount") @db.Decimal(15, 2)
  fiscalCount    Int      @default(0) @map("fiscal_count")
  shiftIds       String[] @map("shift_ids")
  createdAt      DateTime @default(now()) @map("created_at")
  // ⚠️ IMMUTABLE — no updatedAt, cannot be modified
  createdBy      String   @map("created_by")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, sequenceNumber])
  @@unique([tenantId, date]) // bir kunda faqat bitta Z-report
  @@index([tenantId])
  @@index([tenantId, date])
  @@map("z_reports")
}

