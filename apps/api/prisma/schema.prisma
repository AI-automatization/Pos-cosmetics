// ============================================
// WAREHOUSE INVOICES (T-327)
// ============================================

model WarehouseInvoice {
  id            String                 @id @default(uuid())
  tenantId      String                 @map("tenant_id")
  branchId      String?                @map("branch_id")
  supplierId    String?                @map("supplier_id")
  invoiceNumber String?                @map("invoice_number")
  note          String?
  totalCost     Decimal                @default(0) @map("total_cost") @db.Decimal(15, 2)
  createdBy     String                 @map("created_by")
  createdAt     DateTime               @default(now()) @map("created_at")
  status        WarehouseInvoiceStatus @default(PENDING)
  approvedBy    String?                @map("approved_by")
  approvedAt    DateTime?              @map("approved_at")
  // ⚠️ Items/totalCost are IMMUTABLE after creation — only status transitions allowed
  //    PENDING → RECEIVED (approve) or PENDING → CANCELLED (reject)

  items WarehouseInvoiceItem[]

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, supplierId])
  @@map("warehouse_invoices")
}

enum WarehouseInvoiceStatus {
  PENDING
  RECEIVED
  CANCELLED
}

model WarehouseInvoiceItem {
  id            String           @id @default(uuid())
  tenantId      String           @map("tenant_id")
  invoiceId     String           @map("invoice_id")
  productId     String           @map("product_id")
  quantity      Int
  purchasePrice Decimal          @map("purchase_price") @db.Decimal(15, 2)
  totalCost     Decimal          @map("total_cost") @db.Decimal(15, 2)
  warehouseId   String?          @map("warehouse_id")
  batchNumber   String?          @map("batch_number")
  expiryDate    DateTime?        @map("expiry_date")

  invoice       WarehouseInvoice @relation(fields: [invoiceId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([tenantId, invoiceId])
  @@index([invoiceId])
  @@index([productId])
  @@map("warehouse_invoice_items")
}

// ============================================
// SUPPORT CRM (T-305)
// ============================================

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TicketSenderType {
  USER
  SUPPORT
}

model SupportTicket {
  id          String         @id @default(uuid())
  tenantId    String         @map("tenant_id")
  userId      String         @map("user_id")
  subject     String
  description String
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(MEDIUM)
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  messages    TicketMessage[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([userId])
  @@map("support_tickets")
}

model TicketMessage {
  id         String           @id @default(uuid())
  tenantId   String           @map("tenant_id")
  ticketId   String           @map("ticket_id")
  senderType TicketSenderType @map("sender_type")
  senderId   String?          @map("sender_id")
  message    String
  createdAt  DateTime         @default(now()) @map("created_at")

  ticket     SupportTicket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, ticketId])
  @@index([ticketId])
  @@map("ticket_messages")
}

// ============================================
// TASKS MODULE
// ============================================

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
}

model Task {
  id          String     @id @default(uuid())
  tenantId    String     @map("tenant_id")
  title       String
  description String?
  status      TaskStatus @default(PENDING)
  assigneeId  String?    @map("assignee_id")
  dueDate     DateTime?  @map("due_date")
  createdById String     @map("created_by_id")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  tenant      Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("tasks")
}

// ============================================
// REAL ESTATE MODULE (T-350)
// ============================================

enum PropertyType {
  OFFICE
  WAREHOUSE
  RETAIL
  APARTMENT
}

enum PropertyStatus {
  RENTED
  VACANT
  MAINTENANCE
}

enum RentalPaymentStatus {
  PAID
  PENDING
  OVERDUE
}

model Property {
  id          String         @id @default(uuid())
  tenantId    String         @map("tenant_id")
  name        String
  address     String
  type        PropertyType   @default(OFFICE)
  status      PropertyStatus @default(VACANT)
  rentAmount  Decimal        @map("rent_amount") @db.Decimal(15, 2)
  currency    String         @default("UZS")
  area        Decimal?       @db.Decimal(10, 2)
  roi         Decimal?       @db.Decimal(5, 2)
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  tenant    Tenant          @relation(fields: [tenantId], references: [id])
  contracts RentalContract[]
  payments  RentalPayment[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("properties")
}

model RentalContract {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  propertyId  String   @map("property_id")
  lesseeName  String   @map("lessee_name")
  lesseePhone String?  @map("lessee_phone")
  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  property Property @relation(fields: [propertyId], references: [id])

  @@index([tenantId])
  @@index([propertyId])
  @@map("rental_contracts")
}

model RentalPayment {
  id         String              @id @default(uuid())
  tenantId   String              @map("tenant_id")
  propertyId String              @map("property_id")
  lesseeName String              @map("lessee_name")
  amount     Decimal             @db.Decimal(15, 2)
  currency   String              @default("UZS")
  dueDate    DateTime            @map("due_date")
  paidDate   DateTime?           @map("paid_date")
  status     RentalPaymentStatus @default(PENDING)
  month      String              // "2026-04"
  note       String?
  createdAt  DateTime            @default(now()) @map("created_at")
  updatedAt  DateTime            @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  property Property @relation(fields: [propertyId], references: [id])

  @@index([tenantId])
  @@index([propertyId])
  @@index([tenantId, status])
  @@map("rental_payments")
}
