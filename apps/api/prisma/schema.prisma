// ============================================
// LEDGER MODULE (T-035) — Double-Entry Journal (IMMUTABLE)
// ============================================

enum LedgerAccount {
  CASH
  ACCOUNTS_RECEIVABLE
  REVENUE
  SALES_RETURN
  COST_OF_GOODS_SOLD
  EXPENSES
}

enum LedgerLineType {
  DEBIT
  CREDIT
}

enum JournalRefType {
  SALE
  PAYMENT
  RETURN
  ADJUSTMENT
}

model JournalEntry {
  id            String         @id @default(uuid())
  tenantId      String         @map("tenant_id")
  referenceType JournalRefType @map("reference_type")
  referenceId   String         @map("reference_id")
  description   String?
  createdAt     DateTime       @default(now()) @map("created_at")
  // ⚠️ updatedAt YO'Q — IMMUTABLE

  lines JournalLine[]

  @@index([tenantId])
  @@index([tenantId, referenceType, referenceId])
  @@map("journal_entries")
}

model JournalLine {
  id             String         @id @default(uuid())
  journalEntryId String         @map("journal_entry_id")
  account        LedgerAccount
  type           LedgerLineType
  amount         Decimal        @db.Decimal(15, 2)
  createdAt      DateTime       @default(now()) @map("created_at")
  // ⚠️ updatedAt YO'Q — IMMUTABLE

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id])

  @@index([journalEntryId])
  @@index([account])
  @@map("journal_lines")
}

