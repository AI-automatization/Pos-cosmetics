{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "prisma generate && nest build",
    "start": "node dist/main",
    "start:prod": "node dist/main",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
