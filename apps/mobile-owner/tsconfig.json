{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext"],
    "jsx": "react-native",
    "moduleResolution": "bundler",
    "strict": true,
    "noImplicitAny": true,
    "paths": {
      "@/*": ["./src/*"],
      "@raos/types": ["../../packages/types/src/index.ts"]
    }
  },
  "include": ["src", "index.ts"],
  "exclude": ["node_modules"]
}
