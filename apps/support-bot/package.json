    "dotenv": "^17.4.2",
    "grammy": "^1.30.0",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@types/node-cron": "^3.0.11",
    "prisma": "^6.4.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3"
  }
}
