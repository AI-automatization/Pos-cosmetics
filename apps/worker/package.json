{
  "name": "worker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "jest": {
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.json"
        }
      ]
    },
    "testMatch": [
      "**/__tests__/**/*.spec.ts"
    ],
    "moduleFileExtensions": [
      "ts",
      "js",
      "json"
    ],
    "moduleNameMapper": {
      "^bullmq$": "<rootDir>/node_modules/bullmq/dist/cjs/index.js",
      "^uuid$": "<rootDir>/__mocks__/uuid.js",
      "^@raos/catalog-import$": "<rootDir>/../../packages/catalog-import/src/index.ts"
    }
  },
  "dependencies": {
    "@prisma/client": "^6.4.1",
    "@raos/catalog-import": "workspace:*",
    "bullmq": "^5.34.8",
    "dotenv": "^17.3.1",
    "ioredis": "^5.11.0",
    "nodemailer": "^6.10.1"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^22.13.0",
    "@types/nodemailer": "^6.4.17",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.6",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3"
  }
}
