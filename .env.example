# Database
DATABASE_URL=postgresql://raos:raos_secret@localhost:5433/raos_dev

# Redis
REDIS_HOST=localhost
REDIS_PORT=6380

# MinIO (S3-compatible)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=raos_minio
MINIO_SECRET_KEY=raos_minio_secret
MINIO_BUCKET=raos-uploads

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
