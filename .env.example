# Database
DATABASE_URL=postgresql://raos:raos_secret@localhost:5433/raos_dev

# Redis
REDIS_HOST=localhost
REDIS_PORT=6380

# MinIO (S3-compatible)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=raos_minio
MINIO_SECRET_KEY=raos_minio_secret
MINIO_BUCKET=raos-uploads

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# API
API_PORT=3003
API_PREFIX=api/v1

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3003/api/v1

# Node
NODE_ENV=development

# ─── Telegram Bot (T-040) ─────────────────────────────────────
# @BotFather dan olinadi
BOT_TOKEN=your-telegram-bot-token-here

# Admin chat ID (alerts shu yerga ketadi)
# Qanday topish: @userinfobot ga yozing
# Ko'p admin: vergul bilan ajrating "-100123456,-100654321"
BOT_ADMIN_CHAT_IDS=-100123456789

# Alert sozlamalari
REFUND_ALERT_THRESHOLD=500000    # 500,000 so'mdan katta qaytarish — alert
EXPIRY_DAYS_WARNING=30           # 30 kun ichida muddati tugaydigan
LOW_STOCK_CRON=0 * * * *         # Har soat
EXPIRY_CHECK_CRON=0 8 * * *      # Har kuni soat 08:00
