# ═══════════════════════════════════════════════════════════════
# RAOS API — Environment Variables
# LOCAL: cp .env.example .env
# RAILWAY: set these in Variables tab (see comments below)
# ═══════════════════════════════════════════════════════════════

# ─── Database ─────────────────────────────────────────────────
# LOCAL: docker-compose up postgres
# RAILWAY: Add PostgreSQL service → DATABASE_URL auto-injected
DATABASE_URL=postgresql://raos:raos_secret@localhost:5433/raos_dev

# ─── Redis ────────────────────────────────────────────────────
# LOCAL: docker-compose up redis
# RAILWAY: Add Redis service → REDIS_URL or REDIS_HOST/PORT auto-injected
# Option A (Railway): REDIS_URL=redis://:password@host:port
# Option B (manual):
REDIS_HOST=localhost
REDIS_PORT=6380
# REDIS_PASSWORD=   # optional

# ─── MinIO / S3 ───────────────────────────────────────────────
# LOCAL: docker-compose up minio
# RAILWAY: Use external S3 (Cloudflare R2 / AWS S3) or Railway MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=raos_minio
MINIO_SECRET_KEY=raos_minio_secret
MINIO_BUCKET=raos-uploads
# MINIO_USE_SSL=false   # set true for production S3

# ─── JWT ──────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── API ──────────────────────────────────────────────────────
# RAILWAY: PORT is auto-injected by Railway — do NOT set PORT manually
API_PORT=3003
API_PREFIX=api/v1
CORS_ORIGIN=http://localhost:3001

# ─── Frontend ─────────────────────────────────────────────────
# RAILWAY: Set to actual Railway API service URL
NEXT_PUBLIC_API_URL=http://localhost:3003/api/v1

# ─── Node ─────────────────────────────────────────────────────
NODE_ENV=development

# ─── Telegram Bot ─────────────────────────────────────────────
# @BotFather dan olinadi
BOT_TOKEN=your-telegram-bot-token-here
# Bot username (@belgisisiz) — link yaratish uchun
BOT_USERNAME=raos_bot
# Admin chat ID (alerts shu yerga ketadi)
# Qanday topish: @userinfobot ga yozing
# Ko'p admin: vergul bilan ajrating "-100123456,-100654321"
BOT_ADMIN_CHAT_IDS=-100123456789
# API internal URL (bot → API murojaat uchun, Docker ichida)
API_INTERNAL_URL=http://localhost:3003/api/v1

# ─── Super Admin Bootstrap ────────────────────────────────────
# POST /api/v1/admin/auth/bootstrap da ishlatiladigan bir martalik secret
# Birinchi Super Admin yaratilgandan keyin bu endpoint ishlamaydi
ADMIN_BOOTSTRAP_SECRET=change-this-to-random-secret-string

# ─── Metrics (T-348) ──────────────────────────────────────────
# Prometheus scraper uchun: --header 'X-Metrics-Secret: <bu qiymat>'
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
METRICS_SECRET=change-this-to-random-secret-string

# ─── REGOS / OFD Fiscal (T-081) ──────────────────────────────
# Soliq idorasi OFD integratsiyasi
# Yo'q bo'lsa: STUB rejimi ishlaydi (dev/test uchun)
# RAILWAY: Variables tabidan qo'shish
# REGOS_API_URL=https://api.regos.uz/v1
# REGOS_API_KEY=your-regos-api-key-here

# ─── Payme ────────────────────────────────────────────────────
# https://developer.paycom.uz/ dan olinadi
PAYME_MERCHANT_ID=your-payme-merchant-id
PAYME_SECRET_KEY=your-payme-secret-key

# ─── Click ────────────────────────────────────────────────────
# https://my.click.uz → settings dan olinadi
CLICK_SERVICE_ID=your-click-service-id
CLICK_MERCHANT_ID=your-click-merchant-id
CLICK_SECRET_KEY=your-click-secret-key

# ─── SMTP Email (Telegram fallback, BEPUL) ────────────────────
# Gmail: "App Password" yarating (2FA yoqilgan bo'lsa)
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=RAOS <your-email@gmail.com>

# ─── Alert thresholds ─────────────────────────────────────────
REFUND_ALERT_THRESHOLD=500000
EXPIRY_DAYS_WARNING=30
LOW_STOCK_CRON=0 * * * *
EXPIRY_CHECK_CRON=0 8 * * *
